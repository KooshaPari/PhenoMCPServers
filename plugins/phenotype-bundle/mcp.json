{
  "mcpServers": {
    "substrate": {
      "command": "python",
      "args": ["servers/substrate/substrate_server.py"],
      "env": {
        "SUBSTRATE_HTTP_URL": "http://127.0.0.1:8080",
        "SUBSTRATE_TEAM_ID": "default",
        "SUBSTRATE_AGENT_NAME": "lead"
      }
    },
    "substrate-dispatch": {
      "command": "python",
      "args": ["servers/substrate/dispatch_server.py"],
      "env": {
        "OMNIROUTE_URL": "http://127.0.0.1:20128"
      }
    },
    "pheno-org": {
      "command": "python",
      "args": ["servers/pheno-org/pheno_org_server.py"],
      "env": {
        "PARPOURA_BASE_URL": "http://127.0.0.1:8001"
      }
    }
  }
}
