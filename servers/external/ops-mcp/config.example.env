# Example environment for phenotype-ops-mcp
# Copy these values into your local shell, launchd plist, or container runtime.
# Do not commit real production endpoints or secrets.

# Required OmniRoute base URL.
OMNIROUTE_URL=http://127.0.0.1:20128

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# Comma-separated tool names exposed by the server.
TOOL_ALLOWLIST=health,dispatch,delegate

# Maximum allowed execution time for a delegated call.
MAX_EXEC_TIMEOUT=30s

# Maximum number of parallel delegated calls.
MAX_PARALLEL=4
